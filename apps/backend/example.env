NX_DB_HOST=localhost
NX_DB_PORT=5432
NX_DB_USERNAME=postgres
NX_DB_PASSWORD=
NX_DB_DATABASE=

NX_AWS_ACCESS_KEY=your_aws_access_key
NX_AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

NX_COGNITO_USER_POOL_ID=
NX_COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
REGION=

ADMIN_EMAIL=
ADMIN_PASSWORD=

# Set to true to seed 10 mock applications in the SCREENING round on startup (skipped if any applications already exist)
SEED_MOCK_APPLICATIONS=false

# ─── DEV ONLY ─ remove before shipping ───────────────────────────────────────
# Bypass Cognito JWT verification — accepts X-Dev-User-Email header instead.
# NEVER enable in production.
DEV_AUTH_BYPASS=false
# Seed 10 fake recruiters (@dev.local emails) on startup for use with DEV_AUTH_BYPASS.
SEED_MOCK_RECRUITERS=false
# ─────────────────────────────────────────────────────────────────────────────